@startuml
left to right direction
skinparam componentStyle uml2
skinparam shadowing false
skinparam linetype ortho

package "Even/Odd Processing System" {
  component "Even/Odd Sorter" as Sorter {
    portout "even out" as SO_E
    portout "odd out" as SO_O
  }

  component "Even/Odd Verifier" as Verifier {
    portin "even in" as VI_E
    portin "odd in" as VI_O
    portout "output" as V_OUT
  }

  component "RPC OpNet Bridge" as Bridge
  interface "RPC" as RPC_IF
}

SO_E -right-> VI_E
SO_O -right-> VI_O
V_OUT -down-> Bridge
Bridge -left-> Sorter : Input
Bridge -down-> RPC_IF : request
RPC_IF -up-> Bridge : response

note bottom of Bridge
Smoke test injects 100 random numbers via RPC.
All verdicts must be "pass".
end note
@enduml
